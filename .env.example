# GitHub OAuth
# https://github.com/settings/developers でOAuthアプリを作成して取得
GITHUB_ID=
GITHUB_SECRET=

# NextAuth
# 以下のコマンドで生成: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Supabase
# https://supabase.com のプロジェクト設定から取得
DATABASE_URL=

# Upstash Redis
# https://upstash.com のコンソールから取得
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Discord Bot
# https://discord.com/developers/applications でBotを作成して取得
DISCORD_TOKEN=
DISCORD_GUILD_ID=
