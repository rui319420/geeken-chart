# GitHub OAuth
# https://github.com/settings/developers でOAuthアプリを作成して取得
GITHUB_ID=
GITHUB_SECRET=

# NextAuth
# 以下のコマンドで生成: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Supabase の Session mode（ポート5432）← Prisma migrate/push 用
DATABASE_URL=""

# Supabase の Transaction mode（ポート6543）← アプリ実行時用
DIRECT_URL=""

# Upstash Redis
# https://upstash.com のコンソールから取得
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Discord Bot
# https://discord.com/developers/applications でBotを作成して取得
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Vercel
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=