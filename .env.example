# GitHub OAuth
# https://github.com/settings/developers でOAuthアプリを作成して取得
GITHUB_ID=
GITHUB_SECRET=

# NextAuth
# 以下のコマンドで生成: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Supabase
# https://supabase.com のプロジェクト設定から取得
DATABASE_URL=

# Prisma
# Session mode（Prismaのマイグレーション用）
DATABASE_URL=""  # ポート5432
# Transaction mode（Vercelデプロイ時の接続用）
DIRECT_URL=""    # ポート6543

# Upstash Redis
# https://upstash.com のコンソールから取得
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Discord Bot
# https://discord.com/developers/applications でBotを作成して取得
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Vercel
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=