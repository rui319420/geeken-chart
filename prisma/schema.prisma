// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
// ──────────────────────────────────────
// ユーザー情報
// ──────────────────────────────────────
model User {
  id           String   @id @default(cuid())
	name         String?
  githubId     String   @unique
  githubName   String
  nickname     String?
  avatarUrl    String?
	email         String?  @unique
	emailVerified DateTime?
	image         String?
	accounts      Account[]
	sessions      Session[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // プライバシー設定
  showCommits   Boolean @default(true)
  showLanguages Boolean @default(true)
  joinRanking   Boolean @default(true)
  isAnonymous   Boolean @default(false)
	includePrivate Boolean @default(false)

  // リレーション
  languages       UserLanguage[]
	snapshots     LanguageSnapshot[]
  discordActivity DiscordActivity[]
	discordId String? @unique

  // ランキング用 GitHub Stats データ
  githubScore     Int?
  totalCommits    Int?
  totalStars      Int?
  totalPRs        Int?
  totalIssues     Int?
  statsUpdatedAt  DateTime?

  @@index([joinRanking, githubScore(sort: Desc)])
}

// ──────────────────────────────────────
// 使用言語（メンバーごと）
// ──────────────────────────────────────
model UserLanguage {
  id        String   @id @default(cuid())
  userId    String
  language  String
  bytes     Int
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, language]) // 同じユーザー×言語の組み合わせは1件のみ
}

model LanguageSnapshot {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  language String
  bytes    BigInt
  month    String // "2026-03" 形式（YYYY-MM）

  @@unique([userId, language, month])
}

// ──────────────────────────────────────
// Discord 活動時間帯（Bot が書き込む）
// ──────────────────────────────────────
model DiscordActivity {
  id           String   @id @default(cuid())
  userId       String
  dayOfWeek    Int      // 0=月, 1=火, ..., 6=日
  hour         Int      // 0〜23
  messageCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, hour])
}

// ──────────────────────────────────────
// NextAuth.js 用テーブル（既存のschema.prismaの末尾に追記）
// ──────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RawDiscordActivity {
  id            String   @id @default(cuid())
  discordId     String
  weekKey       String   @default("")
  dayOfWeek     Int
  hour          Int
  messageCount  Int      @default(0)
  presenceCount Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([discordId, weekKey, dayOfWeek, hour])
}